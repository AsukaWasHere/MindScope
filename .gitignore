# ─────────────────────────────
# Python
# ─────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
venv/
env/
.venv/

# Environment variables
.env*

# Notebooks
.ipynb_checkpoints/

# ─────────────────────────────
# DATA — generated, regenerated on first run
# (raw source files are in data/raw/ — small, needed for pipeline)
# ─────────────────────────────
data/processed/
data/splits/
data/features/

# ─────────────────────────────
# MODELS — ignore non-artifact files, keep trained .pkl files
# ─────────────────────────────
models/saved/*.txt
models/saved/bert/
models/saved/*.json
models/saved/*.csv

# ─────────────────────────────
# REPORTS — generated locally
# ─────────────────────────────
reports/

# ─────────────────────────────
# FILE TYPES — ignores everything else
# ─────────────────────────────
*.pkl
*.pt
*.png
*.jpg
*.jpeg
*.pdf
*.csv

# ─────────────────────────────
# IDE / OS
# ─────────────────────────────
.vscode/
.idea/
.DS_Store
Thumbs.db

# ─────────────────────────────
# LOGS
# ─────────────────────────────
*.log
logs/

# spaCy
en_core_web_sm/

# pytest
.pytest_cache/
.coverage
htmlcov/